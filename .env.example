# =====
# ENV EXAMPLE
# =====
# Copy this file to '.env' and fill in your details.
# DO NOT commit your actual '.env' file to version control.
# =====

# Discord API Token (Get this from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# PostgreSQL Database Connection URL (e.g. Railway / Supabase / Local)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# The core Server/Guild ID where the bot operates
GUILD_ID=123456789012345678

# The private Asset Server Guild ID.
# Hosts all custom animated emojis and GIF thumbnails used by the bot UI.
# The bot must be a member of this server for custom emoji rendering to work.
ASSET_SERVER_ID=123456789012345678
